# Copy to .env in this folder (or set in shell)
OLLAMA_API_KEY=
OLLAMA_HOST=https://ollama.com
OLLAMA_MODEL=nemotron-3-nano:30b-cloud

# Optional: separate model for generation vs validation (defaults to OLLAMA_MODEL)
# OLLAMA_MODEL_GENERATOR=
# OLLAMA_MODEL_VALIDATOR=

# Experiment size (defaults shown)
# HW3_REPLICATES_PER_PROMPT=6
# HW3_GENERATION_TEMPERATURE_A=0.85
# HW3_GENERATION_TEMPERATURE_B=0.55
# HW3_GENERATION_TEMPERATURE_C=0.35
